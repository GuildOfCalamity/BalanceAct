<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="BalanceAct.Controls.CartesianChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BalanceAct.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="250"
    d:DesignWidth="450"
    mc:Ignorable="d">

    <Grid MinWidth="600" MinHeight="400">
        <Canvas x:Name="PART_Canvas" Background="Transparent">

            <Canvas x:Name="PART_PointLayer" />

            <!--  Highlight  -->
            <Ellipse
                x:Name="PART_HighlightDot"
                Width="14"
                Height="14"
                Fill="DeepSkyBlue"
                Stroke="White"
                StrokeThickness="1"
                Visibility="Collapsed" />
            <!--  Tooltip  -->
            <Border
                x:Name="PART_Tooltip"
                Padding="10,4"
                Background="#AA000000"
                BorderBrush="#AA1E90FF"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="PART_TooltipText"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White" />
            </Border>
        </Canvas>
    </Grid>
</UserControl>
